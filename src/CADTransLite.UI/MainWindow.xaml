<Window x:Class="CADTransLite.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CADTransLite.UI"
        xmlns:status="clr-namespace:CADTransLite.UI"
        mc:Ignorable="d"
        Title="CADTrans Lite v3.4"
        Icon="pack://application:,,,/Images/logo.png"
        Height="780" Width="760"
        MinHeight="680" MinWidth="720"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">

    <Window.DataContext>
        <local:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Primary blue accent color -->
        <SolidColorBrush x:Key="AccentBrush" Color="#1565C0" />
        <SolidColorBrush x:Key="AccentLightBrush" Color="#1976D2" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#E3F2FD" />
        <SolidColorBrush x:Key="OnSurfaceBrush" Color="#212121" />
        <SolidColorBrush x:Key="DisabledBrush" Color="#BDBDBD" />

        <!-- Flat primary button style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1565C0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepButtonStyle" TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#1565C0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0E0E0" />
                    <Setter Property="Foreground" Value="#9E9E9E" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0D47A1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ODA Download button (orange) -->
        <Style x:Key="OdaDownloadButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF9800" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F57C00" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E65100" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Browse button (gray) -->
        <Style x:Key="BrowseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#607D8B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#455A64" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1565C0" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Setting label style -->
        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#424242" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ================================================================
             Main content area
             ================================================================ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,16">

                <!-- ──────────────────────────────────────────────────────────
                     Title
                     ────────────────────────────────────────────────────────── -->
                <TextBlock Text="CADTrans Lite v3.4"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#1565C0" Margin="0,0,0,4" />
                <TextBlock Text="DWG/DXF 文字提取  ›  翻译  ›  回填输出"
                           FontSize="12" Foreground="#757575" Margin="0,0,0,4" />

                <!-- ──────────────────────────────────────────────────────────
                     ODA File Converter Status & Path
                     ────────────────────────────────────────────────────────── -->
                <Border Background="#FAFAFA"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Status indicator dot -->
                            <Ellipse Grid.Column="0"
                                     Width="10" Height="10"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <Binding Path="OdaStatusColor"
                                             Converter="{x:Static local:StringToBrushConverter.Instance}" />
                                </Ellipse.Fill>
                            </Ellipse>

                            <!-- Status text -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding OdaStatusText}"
                                       FontSize="11"
                                       Foreground="#616161"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />

                            <!-- Download button -->
                            <Button Grid.Column="2"
                                    Content="下载 ODA"
                                    Style="{DynamicResource OdaDownloadButtonStyle}"
                                    Command="{Binding OpenOdaDownloadCommand}"
                                    ToolTip="打开 ODA 官网下载页面"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding IsOdaAvailable,
                                        Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}" />

                            <!-- Download button (when available, show Update/Change) -->
                            <Button Grid.Column="2"
                                    Content="更换路径"
                                    Style="{DynamicResource OdaDownloadButtonStyle}"
                                    Command="{Binding OpenOdaDownloadCommand}"
                                    ToolTip="更改 ODA File Converter 路径"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding IsOdaAvailable,
                                        Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}" />
                        </Grid>

                        <!-- Custom ODA path -->
                        <Grid Margin="20,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="ODA路径:"
                                       Style="{DynamicResource SettingLabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding OdaPath, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="11"
                                     Padding="6,4"
                                     VerticalAlignment="Center"
                                     ToolTip="ODA File Converter 可执行文件路径" />
                            <Button Grid.Column="2"
                                    Content="浏览..."
                                    Style="{DynamicResource BrowseButtonStyle}"
                                    Command="{Binding BrowseOdaPathCommand}"
                                    Margin="8,0,0,0"
                                    Padding="10,4"
                                    ToolTip="浏览 ODA File Converter 路径" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ──────────────────────────────────────────────────────────
                     Drop Zone
                     ────────────────────────────────────────────────────────── -->
                <Border Background="White"
                        BorderBrush="#90CAF9"
                        BorderThickness="2"
                        CornerRadius="8"
                        MinHeight="90"
                        Margin="0,0,0,16"
                        Cursor="Hand"
                        MouseLeftButtonUp="DropZone_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentFilePath, Converter={x:Static local:StringToBoolConverter.Instance}}" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD" />
                                    <Setter Property="BorderBrush" Value="#1565C0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="16">
                        <TextBlock Text="📂"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6" />
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#546E7A"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap">
                            <Run Text="拖入 .dwg / .dxf 文件到此处，或" />
                            <Run Text="点击选择文件" Foreground="#1565C0" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Text="{Binding CurrentFilePath}"
                                   FontSize="10"
                                   Foreground="#1565C0"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   MaxWidth="500"
                                   Visibility="{Binding CurrentFilePath,
                                       Converter={x:Static local:StringToVisibilityConverter.Instance}}" />
                    </StackPanel>
                </Border>

                <!-- ──────────────────────────────────────────────────────────
                     Language Selection
                     ────────────────────────────────────────────────────────── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="源语言:"
                               FontSize="12" Foreground="#424242"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding SourceLanguages}"
                              SelectedItem="{Binding SourceLanguage}"
                              DisplayMemberPath="DisplayName"
                              FontSize="12" Padding="6,4" />

                    <TextBlock Grid.Column="3" Text="目标语言:"
                               FontSize="12" Foreground="#424242"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding TargetLanguages}"
                              SelectedItem="{Binding TargetLanguage}"
                              DisplayMemberPath="DisplayName"
                              FontSize="12" Padding="6,4" />

                    <TextBlock Grid.Column="5" Text="翻译引擎:"
                               FontSize="12" Foreground="#424242"
                               VerticalAlignment="Center" Margin="12,0,8,0" />
                    <ComboBox Grid.Column="6"
                              ItemsSource="{Binding TranslationProviders}"
                              SelectedItem="{Binding SelectedProvider}"
                              FontSize="12" Padding="6,4" />
                </Grid>

                <!-- ──────────────────────────────────────────────────────────
                     Settings Panel (Expandable)
                     ────────────────────────────────────────────────────────── -->
                <Expander Header="🔧 自定义设置" IsExpanded="False" Margin="0,0,0,16">
                    <Border Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,12"
                            Margin="0,8,0,0">

                        <StackPanel>

                            <!-- ① Import Settings -->
                            <Expander Header="① 导入设置" IsExpanded="False" Margin="0,0,0,8">
                                <StackPanel Margin="0,8,0,0">

                                    <!-- Element types -->
                                    <TextBlock Text="提取元素类型:" FontWeight="Bold" FontSize="11" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <CheckBox Content="代理对象(自动炸开)"
                                                  IsChecked="{Binding ImportProxyObjects}"
                                                  Margin="0,4,16,4"
                                                  FontSize="11" />
                                        <CheckBox Content="块属性标记"
                                                  IsChecked="{Binding ImportBlockAttributes}"
                                                  Margin="0,4,16,4"
                                                  FontSize="11" />
                                        <CheckBox Content="提示和值"
                                                  IsChecked="{Binding ImportDimensionText}"
                                                  Margin="0,4,16,4"
                                                  FontSize="11" />
                                    </WrapPanel>

                                    <!-- MText processing -->
                                    <TextBlock Text="多行文本处理:" FontWeight="Bold" FontSize="11" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton Content="按段落提取 (推荐)"
                                                     IsChecked="{Binding ImportMTextParagraph}"
                                                     GroupName="MTextMode"
                                                     Margin="0,4,16,4"
                                                     FontSize="11" />
                                        <RadioButton Content="作为整体提取"
                                                     IsChecked="{Binding ImportMTextWhole}"
                                                     GroupName="MTextMode"
                                                     Margin="0,4,16,4"
                                                     FontSize="11" />
                                    </StackPanel>

                                    <!-- Special layers -->
                                    <TextBlock Text="特殊图层处理:" FontWeight="Bold" FontSize="11" Margin="0,0,0,6" />
                                    <WrapPanel>
                                        <CheckBox Content="冻结图层"
                                                  IsChecked="{Binding ImportFrozenLayers}"
                                                  Margin="0,4,16,4"
                                                  FontSize="11"
                                                  ToolTip="启用后将提取冻结图层中的文字" />
                                        <CheckBox Content="锁定图层"
                                                  IsChecked="{Binding ImportLockedLayers}"
                                                  Margin="0,4,16,4"
                                                  FontSize="11"
                                                  ToolTip="启用后将提取锁定图层中的文字" />
                                        <CheckBox Content="关闭图层"
                                                  IsChecked="{Binding ImportOffLayers}"
                                                  Margin="0,4,16,4"
                                                  FontSize="11"
                                                  ToolTip="启用后将提取关闭图层中的文字" />
                                    </WrapPanel>

                                    <!-- Phase 3: Excel format & dedup -->
                                    <TextBlock Text="导出与去重:" FontWeight="Bold" FontSize="11" Margin="0,8,0,6" />
                                    <WrapPanel>
                                        <CheckBox Content="多列Excel格式 (11列)"
                                                  IsChecked="{Binding UseRichExcelFormat}"
                                                  Margin="0,4,16,4"
                                                  FontSize="11"
                                                  ToolTip="启用后导出11列富元数据格式（Handle/类型/图层/原文/清洗/译文/状态等）；关闭则使用传统2列格式" />
                                        <CheckBox Content="清洗后去重"
                                                  IsChecked="{Binding EnableCleanedDedup}"
                                                  Margin="0,4,16,4"
                                                  FontSize="11"
                                                  ToolTip="启用后，合并阶段会按 (类型+清洗文本) 进行二次去重，减少翻译行数" />
                                    </WrapPanel>

                                    <!-- Phase 4: Layout adjustment, Glossary, AI filter, DWG version -->
                                    <TextBlock Text="回填与输出:" FontWeight="Bold" FontSize="11" Margin="0,8,0,6" />
                                    <StackPanel>
                                        <CheckBox Content="启用布局自适应（文字过长自动缩放）"
                                                  IsChecked="{Binding EnableLayoutAdjust}"
                                                  Margin="0,4"
                                                  FontSize="11"
                                                  ToolTip="启用后，当译文比原文长导致文字溢出实体边界时，自动缩放字高使其适应" />
                                        <CheckBox Content="启用术语表替换"
                                                  IsChecked="{Binding EnableGlossary}"
                                                  Margin="0,4"
                                                  FontSize="11"
                                                  ToolTip="启用术语表后，翻译完成时自动应用术语替换" />
                                        <CheckBox Content="启用 AI 智能过滤"
                                                  IsChecked="{Binding EnableAiFilter}"
                                                  Margin="0,4"
                                                  FontSize="11"
                                                  ToolTip="启用后，翻译前自动用 AI 判断哪些文本不需要翻译" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="DWG 输出版本："
                                                       FontSize="11"
                                                       Foreground="#424242"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding OutputVersions}"
                                                      SelectedItem="{Binding SelectedOutputVersion}"
                                                      DisplayMemberPath="DisplayName"
                                                      FontSize="11"
                                                      Padding="6,4"
                                                      ToolTip="选择输出的 DWG 文件版本（需要 ODA File Converter）" />
                                        </Grid>

                                        <!-- Glossary management -->
                                        <StackPanel Margin="0,8,0,0" Visibility="{Binding EnableGlossary, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding GlossaryPath, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Padding="4,2"
                                                         ToolTip="术语表 JSON 文件路径" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                                    <Button Content="浏览" Command="{Binding BrowseGlossaryPathCommand}"
                                                            FontSize="10" Padding="8,2" Margin="2,0" />
                                                    <Button Content="加载" Command="{Binding LoadGlossaryCommand}"
                                                            FontSize="10" Padding="8,2" Margin="2,0" />
                                                    <Button Content="保存" Command="{Binding SaveGlossaryCommand}"
                                                            FontSize="10" Padding="8,2" Margin="2,0" />
                                                </StackPanel>
                                            </Grid>

                                            <DataGrid ItemsSource="{Binding GlossaryEntries}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="True"
                                                      CanUserDeleteRows="True"
                                                      MaxHeight="200"
                                                      FontSize="11"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderThickness="1"
                                                      BorderBrush="#E0E0E0"
                                                      Margin="0,2,0,0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="源术语" Binding="{Binding SourceTerm, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                                    <DataGridTextColumn Header="目标术语" Binding="{Binding TargetTerm, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                                    <DataGridTextColumn Header="源语言" Binding="{Binding SourceLang, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                                                    <DataGridTextColumn Header="目标语言" Binding="{Binding TargetLang, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                                                    <DataGridCheckBoxColumn Header="区分大小写" Binding="{Binding IsCaseSensitive}" Width="Auto" />
                                                    <DataGridTextColumn Header="分类" Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>

                                        <!-- AI filter configuration -->
                                        <StackPanel Margin="0,8,0,0" Visibility="{Binding EnableAiFilter, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                                            <TextBlock Text="AI 过滤配置" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="过滤模型：" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding AiFilterModelName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Padding="4,2"
                                                         ToolTip="留空则复用翻译 API 的模型名" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="过滤 Prompt：" VerticalAlignment="Top" Margin="0,4,4,0" FontSize="11" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding AiFilterPrompt, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Padding="4,2"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MaxHeight="80"
                                                         VerticalScrollBarVisibility="Auto"
                                                         ToolTip="留空使用默认过滤 Prompt。支持占位符：{sourceLang}, {targetLang}, {texts}" />
                                            </Grid>
                                            <TextBlock Text="⚠️ AI 过滤复用「自定义AI」的 API Key 和 Base URL 配置"
                                                       FontSize="10" Foreground="#FF666666" Margin="0,2,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- ② Export Settings -->
                            <Expander Header="② 导出设置" IsExpanded="False" Margin="0,0,0,8">
                                <StackPanel Margin="0,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="导出文件后缀:"
                                                   Style="{DynamicResource SettingLabelStyle}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   FontWeight="Bold" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding ExportSuffix, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12"
                                                 Padding="6,4"
                                                 MaxLength="50"
                                                 VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="Gray">
                                            <Run Text="示例: " /><Run Text="{Binding CurrentFilePath, TargetNullValue='file.dxf'}" FontWeight="Bold" FontSize="9" /><Run Text="{Binding ExportSuffix}" Foreground="#1565C0" />
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="提示: 后缀将添加到输出文件名中，用于区分原文件和翻译文件"
                                               FontSize="10"
                                               Foreground="Gray"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Expander>

                            <!-- ③ Translation API Settings -->
                            <Expander Header="③ 翻译API设置" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0">

                                    <!-- DeepL Translate API -->
                                    <Border Background="#FCE4EC"
                                            BorderBrush="#F48FB1"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Margin="0,0,0,8"
                                            Visibility="{Binding DeepLSettingsVisibility}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- API Key -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="API Key:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding DeepLApiKey, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         FontFamily="Consolas"
                                                         ToolTip="DeepL API 密钥（Free版后缀 :fx）" />
                                                                                            <!-- Test DeepL API Button -->
                                                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Content="测试"
                                                        Command="{Binding TestTranslationApiCommand}"
                                                        CommandParameter="DeepL"
                                                        Style="{DynamicResource BrowseButtonStyle}"
                                                        Margin="0,8,0,0"
                                                        ToolTip="测试 DeepL API 连接" /></Grid>

                                            <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="#616161">
                                                <Run Text="申请地址: " />
                                                <Hyperlink NavigateUri="https://www.deepl.com/pro-api"
                                                           RequestNavigate="Hyperlink_RequestNavigate">
                                                    https://www.deepl.com/pro-api
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>



                                    <!-- Custom AI Model -->
                                    <Border Background="#FFF8E1"
                                            BorderBrush="#FFE082"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Margin="0,0,0,8"
                                            Visibility="{Binding CustomAISettingsVisibility}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- API Key -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="API Key:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         FontFamily="Consolas"
                                                         ToolTip="AI模型的API密钥" />

                                                <!-- Base URL -->
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="Base URL:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         ToolTip="API服务地址，如 https://api.openai.com/v1" />

                                                <!-- Model Name -->
                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                           Text="模型名称:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <ComboBox Grid.Row="2" Grid.Column="1"
                                                          ItemsSource="{Binding ModelNames}"
                                                          Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="True"
                                                          FontSize="11"
                                                          Padding="6,4"
                                                          Margin="0,2" />

                                                <!-- Test Connection Button -->
                                                <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Content="测试"
                                                        Command="{Binding TestTranslationApiCommand}"
                                                        CommandParameter="CustomAI"
                                                        Style="{DynamicResource BrowseButtonStyle}"
                                                        Margin="0,8,0,0"
                                                        ToolTip="测试自定义AI模型连接" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Baidu Translate API -->
                                    <Border Background="#E8F5E9"
                                            BorderBrush="#A5D6A7"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Visibility="{Binding BaiduSettingsVisibility}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- App ID -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="App ID:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding BaiduAppId, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2" />

                                                <!-- App Key -->
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="App Key:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding BaiduAppKey, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         FontFamily="Consolas" />

                                                <!-- Save Settings Button -->
                                                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Content="测试" Command="{Binding TestTranslationApiCommand}" Style="{DynamicResource BrowseButtonStyle}" Margin="0,8,0,0" ToolTip="测试百度翻译API连接" />
                                            </Grid>

                                            <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="#616161">
                                                <Run Text="申请地址: " />
                                                <Hyperlink NavigateUri="https://fanyi-api.baidu.com/"
                                                           RequestNavigate="Hyperlink_RequestNavigate">
                                                    https://fanyi-api.baidu.com/
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tencent Translate API -->
                                    <Border Background="#FFEBEE"
                                            BorderBrush="#EF9A9A"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding TencentSettingsVisibility}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="SecretId:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding TencentSecretId, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         FontFamily="Consolas" />

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="SecretKey:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding TencentSecretKey, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         FontFamily="Consolas" />

                                                <!-- Save Settings Button -->
                                                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Content="测试" Command="{Binding TestTranslationApiCommand}" Style="{DynamicResource BrowseButtonStyle}" Margin="0,8,0,0" ToolTip="测试百度翻译API连接" />
                                            </Grid>

                                            <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="#616161">
                                                <Run Text="申请地址: " />
                                                <Hyperlink NavigateUri="https://cloud.tencent.com/product/tmt"
                                                           RequestNavigate="Hyperlink_RequestNavigate">腾讯云机器翻译</Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Microsoft Translator API (Free) -->
                                    <Border Background="#E3F2FD"
                                            BorderBrush="#90CAF9"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding MicrosoftSettingsVisibility}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="API Key:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding MicrosoftApiKey, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         FontFamily="Consolas" />

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="区域:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding MicrosoftRegion, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         ToolTip="Azure 区域，如 global、eastasia、southeastasia" />

                                                <!-- Save Settings Button -->
                                                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Content="测试" Command="{Binding TestTranslationApiCommand}" Style="{DynamicResource BrowseButtonStyle}" Margin="0,8,0,0" ToolTip="测试百度翻译API连接" />
                                            </Grid>

                                            <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="#616161">
                                                <Run Text="申请地址: " />
                                                <Hyperlink NavigateUri="https://azure.microsoft.com/services/cognitive-services/translator/"
                                                           RequestNavigate="Hyperlink_RequestNavigate">Azure Translator</Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- DeepLX Local Translation -->
                                    <Border Background="#F3E5F5"
                                            BorderBrush="#CE93D8"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding DeepLXSettingsVisibility}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="API 地址:"
                                                           Style="{DynamicResource SettingLabelStyle}"
                                                           Margin="0,4,8,4" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding DeepLXUrl, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11"
                                                         Padding="6,4"
                                                         Margin="0,2"
                                                         ToolTip="DeepLX 本地服务地址" />

                                                <!-- Test API Button -->
                                                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Content="测试"
                                                        Command="{Binding TestTranslationApiCommand}"
                                                        CommandParameter="DeepLX"
                                                        Style="{DynamicResource BrowseButtonStyle}"
                                                        Margin="0,8,0,0"
                                                        Padding="10,6"
                                                        ToolTip="测试 DeepLX 本地翻译连接" />
                                            </Grid>

                                            <TextBlock Text="提示: 需先启动 DeepLX 本地服务，默认地址 http://127.0.0.1:1188"
                                                       FontSize="10" Foreground="#616161" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Translation Status Indicator -->
                                    <status:TranslationStatusIndicator Margin="0,8,0,0" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ──────────────────────────────────────────────────────────
                     Three-Step Buttons
                     ────────────────────────────────────────────────────────── -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Step 1: Extract & Export (with sub-button below) -->
                    <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Stretch">
                        <Button Style="{DynamicResource StepButtonStyle}"
                                Command="{Binding ExtractAndExportCommand}"
                                ToolTip="提取 CAD 中的文字并导出为 Excel 翻译表">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <TextBlock Text="① 提取导出"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="CAD → Excel (原文/译文)"
                                           FontSize="10" Opacity="0.85"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Button>

                        <!-- Export Translation Only button (below ①) -->
                        <Button Style="{DynamicResource BrowseButtonStyle}"
                                Command="{Binding ExportTranslationOnlyCommand}"
                                FontSize="10"
                                Padding="6,4"
                                Margin="4,4,4,0"
                                HorizontalAlignment="Center"
                                ToolTip="导出纯翻译对照表：仅2列(原文/译文)，只含已翻译且去重的条目。类似 DocuTranslate 的纯翻译导出模式。">
                            <TextBlock Text="导出纯翻译"
                                       FontSize="10"
                                       TextWrapping="NoWrap" />
                        </Button>
                    </StackPanel>

                    <!-- Arrow 1 -->
                    <TextBlock Grid.Column="1"
                               Text="▶"
                               FontSize="16" Foreground="#90A4AE"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="8,0,8,0" />

                    <!-- Step 2: Translate -->
                    <Button Grid.Column="2"
                            Style="{DynamicResource StepButtonStyle}"
                            Command="{Binding TranslateCommand}"
                            ToolTip="使用翻译 API 一键翻译 Excel 中的文字">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <TextBlock Text="② 一键翻译"
                                       FontSize="13" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="API 自动翻译 Excel 译文列"
                                       FontSize="10" Opacity="0.85"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Button>

                    <!-- Arrow 2 -->
                    <TextBlock Grid.Column="3"
                               Text="▶"
                               FontSize="16" Foreground="#90A4AE"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="8,0,8,0" />

                    <!-- Step 3: Import & Write-back -->
                    <Button Grid.Column="4"
                            Style="{DynamicResource StepButtonStyle}"
                            Command="{Binding ImportAndWriteBackCommand}"
                            ToolTip="导入已翻译的 Excel 并将译文回填到新 CAD 文件">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <TextBlock Text="③ 导入回填"
                                       FontSize="13" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Excel 译文列 → 新 CAD 文件"
                                       FontSize="10" Opacity="0.85"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ──────────────────────────────────────────────────────────
                     Custom Excel Path Inputs
                     ────────────────────────────────────────────────────────── -->
                <Grid Margin="0,4,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Below 一键翻译: custom Excel path -->
                    <Border Grid.Column="2"
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding TranslateExcelPath, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="10"
                                     Padding="4,2"
                                     VerticalAlignment="Center"
                                     ToolTip="自定义待翻译的 Excel 文件路径（留空则使用上一步生成的 Excel）" />
                            <Button Grid.Column="1"
                                    Content="浏览"
                                    Style="{DynamicResource BrowseButtonStyle}"
                                    Command="{Binding BrowseTranslateExcelCommand}"
                                    FontSize="10"
                                    Padding="6,2"
                                    Margin="4,0,0,0"
                                    ToolTip="选择待翻译的 Excel 文件" />
                        </Grid>
                    </Border>

                    <!-- Below 导入回填: custom Excel path -->
                    <Border Grid.Column="4"
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ImportExcelPath, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="10"
                                     Padding="4,2"
                                     VerticalAlignment="Center"
                                     ToolTip="自定义已翻译的 Excel 文件路径（留空则使用上一步生成的 Excel）" />
                            <Button Grid.Column="1"
                                    Content="浏览"
                                    Style="{DynamicResource BrowseButtonStyle}"
                                    Command="{Binding BrowseImportExcelCommand}"
                                    FontSize="10"
                                    Padding="6,2"
                                    Margin="4,0,0,0"
                                    ToolTip="选择已翻译的 Excel 文件" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- ──────────────────────────────────────────────────────────
                     Progress Bar
                     ────────────────────────────────────────────────────────── -->
                <ProgressBar Height="8"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}"
                             Foreground="#1565C0"
                             Background="#E0E0E0"
                             Margin="0,0,0,8"
                             Visibility="{Binding IsProcessing,
                                 Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />

                <!-- ──────────────────────────────────────────────────────────
                     Statistics
                     ────────────────────────────────────────────────────────── -->
                <TextBlock Text="{Binding StatisticsText}"
                           FontSize="11" Foreground="#1565C0"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"
                           Visibility="{Binding StatisticsText,
                               Converter={x:Static local:StringToVisibilityConverter.Instance}}" />

                <!-- ──────────────────────────────────────────────────────────
                     Status Text Area
                     ────────────────────────────────────────────────────────── -->
                <Border Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        MinHeight="50">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="#424242"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Workflow hint -->
                <TextBlock Margin="0,12,0,0"
                           FontSize="10" Foreground="#9E9E9E"
                           TextWrapping="Wrap">
                    <Run Text="工作流：" FontWeight="SemiBold" />
                    <Run Text="拖入 .dwg/.dxf → ①提取导出（可手动编辑 Excel 译文列）→ ②一键翻译（可选）→ ③导入回填 → 生成新 CAD 文件" />
                </TextBlock>

                <!-- ──────────────────────────────────────────────────────────
                     Donation Section (Collapsible)
                     ────────────────────────────────────────────────────────── -->
                <Expander IsExpanded="False"
                          Header="☕ 打赏支持"
                          FontSize="13" FontWeight="SemiBold"
                          Foreground="#5D4037"
                          Cursor="Hand"
                          HorizontalAlignment="Center"
                          Margin="0,20,0,0">
                    <StackPanel HorizontalAlignment="Center"
                                Margin="0,4,0,16">

                            <!-- QR Code Image -->
                            <Border Background="#FFF8E1"
                                    CornerRadius="6"
                                    Padding="16"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,8">
                                <Image Source="pack://application:,,,/Images/打赏二维码.jpg"
                                       Width="300" Height="300"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       ToolTip="微信扫码打赏" />
                            </Border>

                            <TextBlock Text="微信扫码打赏"
                                       FontSize="10" Foreground="#9E9E9E"
                                       HorizontalAlignment="Center" />

                    </StackPanel>
                </Expander>

                <!-- Author WeChat Public Account (bottom of content) -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,4">
                    <TextBlock Text="作者公众号：" FontSize="11" Foreground="#757575"
                               VerticalAlignment="Center" />
                    <TextBlock FontSize="11" VerticalAlignment="Center">
                        <Hyperlink NavigateUri="http://mp.weixin.qq.com/mp/homepage?__biz=MzA4NjQ2MDYzMA==&amp;hid=1&amp;sn=bb2531d86a7d41ca361cca9081151faa&amp;scene=18#wechat_redirect"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#1565C0"
                                   FontWeight="SemiBold">
                            山医命象卜
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ================================================================
             Status Bar
             ================================================================ -->
        <StatusBar Grid.Row="1"
                   Background="#1565C0"
                   Foreground="White"
                   Height="26">
            <StatusBarItem>
                <TextBlock Text="CADTrans Lite v3.4  •  基于 netDxf + EPPlus + ODA"
                           FontSize="10" Foreground="#BBDEFB" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="100" Height="8"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}"
                             Foreground="#E3F2FD"
                             Background="#0D47A1"
                             Visibility="{Binding IsProcessing,
                                 Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>







